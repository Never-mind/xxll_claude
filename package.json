{
  "name": "quotation",
  "version": "1.0.0",
  "description": "Product quotation system with React, NestJS, and Excel storage.",
  "private": true,
  "main": "server/main.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --tsconfig server/tsconfig.json server/main.ts",
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1",
    "db:migrate:excel": "tsx scripts/migrate-excel-to-mysql.ts",
    "test": "vitest run",
    "build": "tsc -p server/tsconfig.json && vite build --config client/vite.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "mysql2": "^3.22.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "serverless-http": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  }
}
