{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "types": ["node", "express", "multer"],
    "jsx": "react-jsx"
  },
  "include": ["api/**/*.ts", "server/**/*.ts", "shared/**/*.ts", "client/src/**/*.ts", "client/src/**/*.tsx"]
}
