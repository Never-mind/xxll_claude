{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "outDir": "../dist/server",
    "rootDir": "..",
    "types": ["node"]
  },
  "include": ["../server/**/*.ts", "../shared/**/*.ts"],
  "exclude": ["../server/**/*.spec.ts"]
}
